<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">

  <title>{{metaTitle}}</title>
  <meta name="description" content="{{metaDescription}}">
  <link rel="canonical" href="/{{slug}}/">

  <meta property="og:locale" content="en_US">
  <meta property="og:type" content="article">
  <meta property="og:title" content="{{metaTitle}}">
  <meta property="og:description" content="{{metaDescription}}">
  <meta property="og:url" content="/{{slug}}/">
  <meta property="og:site_name" content="CryptoLoveYou.com">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{metaTitle}}">
  <meta name="twitter:description" content="{{metaDescription}}">

  <link rel="stylesheet" href="/wp-content/themes/smart-mag/style.css?ver=10.3.0" type="text/css" media="all">
  <link rel="stylesheet" href="/wp-includes/css/dist/block-library/style.min.css?ver=6.9.1" type="text/css" media="all">

  <style>
    :root { --c-main: #e89b2d; }
    body { background: #0d1623; color: #e8ecf2; font-family: Inter, system-ui, -apple-system, Segoe UI, Arial, sans-serif; }
    .wrap { max-width: 980px; margin: 0 auto; padding: 32px 20px; }
    .card { background: #11223d; border: 1px solid #2a3f5f; border-radius: 12px; padding: 22px; }
    h1 { font-size: 34px; line-height: 1.2; margin: 0 0 10px; }
    h2 { font-size: 22px; margin: 26px 0 10px; }
    p { font-size: 17px; line-height: 1.7; margin: 0 0 14px; color: #d6dbe4; }
    .meta { display:flex; flex-wrap:wrap; gap:10px; font-size: 13px; color:#aeb7c7; margin: 10px 0 18px; }
    .pill { padding: 4px 10px; border-radius: 999px; background:#0b1a30; border:1px solid #2a3f5f; }
    .cta { display:inline-block; margin-top: 14px; padding: 12px 16px; border-radius: 10px; background: var(--c-main); color:#0d1623; font-weight: 700; text-decoration:none; }
    .cta:hover { filter: brightness(1.05); }
    ul { margin: 10px 0 0 20px; }
    a { color: #87b6ff; }
    .disclaimer { margin-top: 18px; font-size: 13px; color:#aeb7c7; }
    .disclaimer strong { color:#e8ecf2; }
    code { background:#0b1a30; padding:2px 6px; border-radius:6px; border:1px solid #2a3f5f; color:#e8ecf2; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <h1>{{title}}</h1>

      <div class="meta">
        {{#if lastUpdated}}
          <span class="pill">Last updated: {{lastUpdated}}</span>
        {{/if}}
        {{#if coin}}
          {{#if coin.name}}<span class="pill">{{coin.name}}{{#if coin.symbol}} ({{coin.symbol}}){{/if}}</span>{{/if}}
          {{#if coin.percent_change_24h}}<span class="pill">24h: {{coin.percent_change_24h}}%</span>{{/if}}
          {{#if coin.market_cap_rank}}<span class="pill">Rank: #{{coin.market_cap_rank}}</span>{{/if}}
          {{#if coin.total_volume_24h_usd}}<span class="pill">24h vol: {{coin.total_volume_24h_usd}}</span>{{/if}}
        {{/if}}
      </div>

      <p>{{sections.intro}}</p>

      <h2>Why {{#if coin}}{{coin.name}}{{else}}This Coin{{/if}} Is Trending Today</h2>
      <p>{{sections.trend_analysis}}</p>

      <h2>Market Sentiment</h2>
      <p>{{sections.market_sentiment}}</p>

      <h2>Risks to Consider</h2>
      <p>{{sections.risks}}</p>

      <h2>Conclusion</h2>
      <p>{{sections.conclusion}}</p>

      {{#if internal_links.length}}
      <h2>Explore More</h2>
      <ul>
        {{#each internal_links}}
          <li><a href="{{this}}">{{this}}</a></li>
        {{/each}}
      </ul>
      {{/if}}

      <a class="cta" href="/aff/{{cta.platform}}?article={{slug}}">{{cta.text}}</a>

      <p class="disclaimer">
        <strong>Disclosure:</strong> Some links may be affiliate links. <strong>Not financial advice.</strong> DeFi yield involves risk; always do your own research.
      </p>
    </div>
  </div>
</body>
</html>

