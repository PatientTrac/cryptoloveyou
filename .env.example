# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# HubSpot Configuration
HUBSPOT_API_KEY=your_hubspot_api_key_here
HUBSPOT_PORTAL_ID=your_portal_id_here

# Resend (contact form notifications) — https://resend.com
# Domain cryptoloveyou.io verified in Resend; use addresses from that domain only.
# Create an API key in the Resend dashboard; never commit the real key.
RESEND_API_KEY=re_your_resend_api_key_here
# Comma-separated inbox(es) that receive new contact submissions (e.g. contact@, info@).
RESEND_NOTIFY_TO=contact@cryptoloveyou.io
# Verified sender - must be from verified domain (@cryptoloveyou.io)
RESEND_FROM=Crypto Love You <reply@cryptoloveyou.io>
# Optional: Reply-To on the visitor auto-reply (defaults to first RESEND_NOTIFY_TO).
RESEND_REPLY_TO=contact@cryptoloveyou.io
# Optional: subject line for auto-reply; set RESEND_AUTO_REPLY=false to turn off auto-reply only.
RESEND_AUTO_REPLY_SUBJECT=We received your message — Crypto Love You
# RESEND_AUTO_REPLY=false

# Phase 2: AI Content Generation APIs
LUNARCRUSH_API_KEY=your_lunarcrush_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here_optional

# Article Generation Security
ARTICLE_GENERATION_API_KEY=generate_random_secure_key_minimum_32_chars

# Admin portal authentication
# JWT secret for signing session tokens (min 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=generate_random_secure_key_minimum_32_chars

# LEGACY: Old API key system (backwards compatibility - will be deprecated)
# Keep this set during transition period, then remove after all users migrated to username/password
ADMIN_API_KEY=generate_random_secure_key_minimum_32_chars

# Supabase article storage (optional; OFF by default)
# When false/empty, publishing uses direct JSON payloads and filesystem-only sitemap.
ENABLE_SUPABASE_ARTICLES=false

# Local testing (recommended)
# When true, generated pages are written to disk but NOT committed/pushed.
SKIP_GIT_COMMIT=true
SKIP_GIT_PUSH=true

# Affiliate URLs (provide your referral links)
BINANCE_AFFILIATE_URL=https://accounts.binance.com/register?ref=YOUR_REF
COINBASE_AFFILIATE_URL=https://coinbase.com/join/YOUR_REF
BYBIT_AFFILIATE_URL=https://partner.bybit.com/b/YOUR_REF
LEDGER_AFFILIATE_URL=https://shop.ledger.com?r=YOUR_REF
TREZOR_AFFILIATE_URL=https://trezor.io/?offer_id=YOUR_ID

# Optional: Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Grok chat (Netlify function grok-chat.js — floating widget on all pages)
# https://console.x.ai — never commit the real key.
GROK_API_KEY=xai_your_key_here
# Model: Use grok-4.20-reasoning or check available models at https://docs.x.ai/docs/models
GROK_MODEL=grok-4.20-reasoning

# Environment
NODE_ENV=development
